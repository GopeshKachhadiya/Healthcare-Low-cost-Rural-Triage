# Copy this file to .env.local and fill in your deployed backend URLs.
# .env.local is gitignored — never commit real secrets.

# Patient Orchestrator (FastAPI on port 9000 locally)
VITE_API_BASE_URL=http://localhost:9000

# CV/ML Screening service (YOLO/TFLite skin-photo server on port 8005 locally)
VITE_CV_API_BASE_URL=http://localhost:8005

# Appointment Manager agent A1 (FastAPI on port 8011 locally)
VITE_A1_URL=http://localhost:8011

# Hospital AI prediction service (Brain MRI on port 8003, X-ray on port 8004)
# The port is substituted at runtime for modality-specific services.
VITE_HOSPITAL_AI_URL=http://localhost:8003
