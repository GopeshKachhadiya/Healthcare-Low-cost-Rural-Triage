# Anvaya — Environment Variables
# Copy this to .env and fill in your keys. NEVER commit .env to git.

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# OpenRouter (free tier — sign up at openrouter.ai)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Bhashini API (Government of India — free for qualifying projects)
BHASHINI_API_KEY=your-bhashini-key-here

# n8n Webhook Base URL (self-hosted or cloud)
N8N_WEBHOOK_BASE_URL=http://localhost:5678/webhook

# WhatsApp Cloud API (Meta Business)
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# Hugging Face (for deployed model spaces)
HF_USERNAME=your-hf-username
HF_API_TOKEN=your-hf-api-token

# Resend (for email notifications — free tier available)
RESEND_API_KEY=re_your-resend-key-here

# Agent Ports (used by orchestrators to call each other)
R1_URL=http://localhost:8001
R2_URL=http://localhost:8002
RAG_URL=http://localhost:8031
S1_URL=http://localhost:8021
S2_URL=http://localhost:8022
A1_URL=http://localhost:8011
A2_URL=http://localhost:8012
A4_URL=http://localhost:8014
A5_URL=http://localhost:8015
A6_URL=http://localhost:8016
M1_URL=http://localhost:8041
